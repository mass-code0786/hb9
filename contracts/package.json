{
  "name": "halal-business-contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:bsc-testnet": "hardhat run scripts/deploy.js --network bscTestnet",
    "deploy:bsc-mainnet": "hardhat run scripts/deploy-bsc-mainnet.js --network bscMainnet",
    "deploy:check:bsc-mainnet": "set HB_DEPLOY_CHECK_ONLY=true&& hardhat run scripts/deploy-bsc-mainnet.js --network bscMainnet",
    "verify:bsc-testnet": "hardhat run scripts/verify-bsc-testnet.js --network bscTestnet",
    "verify:bsc-mainnet": "hardhat run scripts/verify-bsc-mainnet.js --network bscMainnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@openzeppelin/contracts": "^5.0.2",
    "dotenv": "^17.4.2",
    "hardhat": "^2.22.10"
  }
}
